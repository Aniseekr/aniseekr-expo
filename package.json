{
  "name": "aniseekr",
  "version": "1.1.7",
  "license": "Apache-2.0",
  "author": "Aniseekr <gm@aniseekr.moe> (https://aniseekr.moe)",
  "homepage": "https://aniseekr.moe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aniseekr/aniseekr-expo.git"
  },
  "bugs": {
    "url": "https://github.com/Aniseekr/aniseekr-expo/issues",
    "email": "gm@aniseekr.moe"
  },
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "postinstall": "node scripts/patch-react-native-worklets.mjs",
    "eas-build-pre-install": "bash scripts/install-metal-toolchain.sh",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "test": "bun test --preload ./test-setup.ts",
    "test:unit": "SKIP_INTEGRATION=1 bun test --preload ./test-setup.ts __tests__/unit",
    "test:integration": "bun test --preload ./test-setup.ts __tests__/integration",
    "test:parity": "bun test --preload ./test-setup.ts __tests__/parity",
    "typecheck": "tsc --noEmit",
    "spec:check": "bun run scripts/check-spec-traceability.ts",
    "build:anitabi-index": "bun run scripts/build-anitabi-index.ts",
    "web": "expo start --web",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:android:local": "npx eas-cli build --platform android --profile production --local",
    "build:ios:local": "npx eas-cli build --platform ios --profile production --local",
    "submit:android": "./scripts/android-submit.sh",
    "gcp:bootstrap": "./scripts/gcp-bootstrap.sh",
    "gcp:rotate-key": "./scripts/gcp-rotate-key.sh"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@gorhom/portal": "1.0.14",
    "@maplibre/maplibre-react-native": "11.3.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@shopify/flash-list": "^2.3.1",
    "@shopify/react-native-skia": "2.2.12",
    "@tailwindcss/postcss": "^4.1.13",
    "expo": "^54.0.0",
    "expo-auth-session": "^7.0.10",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "^15.0.8",
    "expo-file-system": "^19.0.21",
    "expo-haptics": "^15.0.8",
    "expo-image": "^3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.14",
    "expo-router": "^6.0.17",
    "expo-screen-orientation": "~9.0.9",
    "expo-secure-store": "^15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.8",
    "nativewind": "preview",
    "opencc-js": "1.3.1",
    "piexif-ts": "^2.1.0",
    "postcss": "^8.5.6",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-clarity": "4.6.2",
    "react-native-cloud-storage": "^3.0.0",
    "react-native-css": "latest",
    "react-native-gesture-handler": "^2.29.1",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "4.0.3",
    "react-native-vision-camera": "^5.0.10",
    "react-native-vision-camera-resizer": "^5.0.10",
    "react-native-vision-camera-worklets": "5.0.10",
    "react-native-worklets": "0.7.4",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/bun": "^1.3.13",
    "@types/react": "~19.1.10",
    "@types/supercluster": "^7.1.3",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.9.2"
  },
  "main": "expo-router/entry",
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
