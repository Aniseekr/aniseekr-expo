{
  "expo": {
    "name": "AniSeekr",
    "slug": "aniseekr",
    "version": "0.0.1",
    "scheme": "aniseekr",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "./plugins/with-vibration-bridge.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6200EE",
          "sounds": []
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kidneyweakx.aniseekr"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kidneyweakx.aniseekr"
    },
    "extra": {
      "eas": {
        "projectId": "f1a05e03-8db4-4188-94bf-11d0cc39bf9a"
      }
    }
  }
}