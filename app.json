          "locationWhenInUsePermission": "AniSeekr uses your location to surface nearby anime pilgrimage spots.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AniSeekr needs access to your photos so you can pick a profile picture.",
