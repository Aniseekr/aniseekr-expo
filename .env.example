# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env`. Comments in dotenv files must start with `#`, not `//`.
#
# Rules:
#   - `EXPO_PUBLIC_*` is inlined into the JS bundle and shipped to every user.
#   - The CLIENT_SECRET values below are EXPO_PUBLIC_ because the iOS App
#     Store binary already bundles them (Config.xcconfig), so matching that
#     posture lets the mobile app complete the auth-code token exchange
#     without a backend proxy. When the Cloudflare Worker proxy is ready,
#     drop the EXPO_PUBLIC_ prefix on the secrets and route token exchange
#     through the proxy.

# --- AniList (auth-code + secret) -------------------------------------------
EXPO_PUBLIC_ANILIST_CLIENT_ID=
EXPO_PUBLIC_ANILIST_CLIENT_SECRET=

# --- MyAnimeList (PKCE plain; no secret on device) --------------------------
EXPO_PUBLIC_MAL_CLIENT_ID=

# --- Bangumi (auth-code + secret) -------------------------------------------
EXPO_PUBLIC_BGM_CLIENT_ID=
EXPO_PUBLIC_BGM_CLIENT_SECRET=

# --- Annict (auth-code + secret) --------------------------------------------
EXPO_PUBLIC_ANNICT_CLIENT_ID=
EXPO_PUBLIC_ANNICT_CLIENT_SECRET=

# --- Simkl (auth-code + secret) ---------------------------------------------
EXPO_PUBLIC_SIMKL_CLIENT_ID=
EXPO_PUBLIC_SIMKL_CLIENT_SECRET=

# --- Shikimori (auth-code + secret) -----------------------------------------
EXPO_PUBLIC_SHIKIMORI_CLIENT_ID=
EXPO_PUBLIC_SHIKIMORI_CLIENT_SECRET=

# --- Kitsu (Resource Owner Password) ----------------------------------------
# Kitsu has not implemented per-app registration yet; their docs publish a
# shared placeholder client_id/secret. Empty strings also work. Fill these in
# only once Kitsu rolls out real app registration.
EXPO_PUBLIC_KITSU_CLIENT_ID=
EXPO_PUBLIC_KITSU_CLIENT_SECRET=

# --- AdMob ad unit IDs (App IDs live in app.json) ---------------------------
# Leave EMPTY in dev so the app falls back to Google's universal test units
# (ca-app-pub-3940256099942544/...). Fill with real unit IDs only when the
# build is going to a public/production track. Real units on an unpublished
# app return "No fill" — that is expected, not a bug.
EXPO_PUBLIC_ADMOB_IOS_BANNER=
EXPO_PUBLIC_ADMOB_IOS_NATIVE=
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL=
EXPO_PUBLIC_ADMOB_IOS_REWARDED=
EXPO_PUBLIC_ADMOB_ANDROID_BANNER=
EXPO_PUBLIC_ADMOB_ANDROID_NATIVE=
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL=
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED=

# --- RevenueCat public SDK keys (one per platform) --------------------------
# Get these from RevenueCat dashboard → Project settings → API keys.
# Android key requires a Play Console service account linked in RevenueCat
# (can reuse secrets/play-sa-key.json or, preferred, mint a separate one
# scoped to "Financial data, order management, and answering inquiries").
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# --- Google Drive OAuth (cloud backup/restore) ------------------------------
# Create OAuth client IDs at console.cloud.google.com -> APIs & Services ->
# Credentials. Web client is required; Android needs the package name +
# signing-cert SHA-1; iOS needs the bundle id. These are public client IDs
# (no secret) - safe to ship in the bundle. iOS can be left empty since iOS
# backs up to iCloud rather than Google Drive.
EXPO_PUBLIC_GOOGLE_DRIVE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_DRIVE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_DRIVE_IOS_CLIENT_ID=
