# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env`. Comments in dotenv files must start with `#`, not `//`.
#
# Rules:
#   - `EXPO_PUBLIC_*` is inlined into the JS bundle and shipped to every user.
#     Only put values that are safe to be public (OAuth client IDs, redirect URIs).
#   - `*_CLIENT_SECRET` MUST NOT be prefixed with `EXPO_PUBLIC_`. These are kept
#     un-prefixed so they stay available to Node-side scripts/tests but never
#     get bundled into the mobile app. The long-term plan is to move secret-
#     using token exchange behind a backend proxy; the app never sees the secret.

# --- AniList (Implicit grant; secret not used by app) -----------------------
EXPO_PUBLIC_ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# --- MyAnimeList (PKCE; no secret on device) --------------------------------
EXPO_PUBLIC_MAL_CLIENT_ID=

# --- Bangumi (OAuth2 + secret; secret must move to backend proxy) -----------
EXPO_PUBLIC_BGM_CLIENT_ID=
BGM_CLIENT_SECRET=

# --- Annict (OAuth2 + secret; secret must move to backend proxy) ------------
EXPO_PUBLIC_ANNICT_CLIENT_ID=
ANNICT_CLIENT_SECRET=

# --- Simkl (OAuth2 + secret; secret must move to backend proxy) -------------
EXPO_PUBLIC_SIMKL_CLIENT_ID=
SIMKL_CLIENT_SECRET=

# --- Shikimori (OAuth2 + secret; secret must move to backend proxy) ---------
EXPO_PUBLIC_SHIKIMORI_CLIENT_ID=
SHIKIMORI_CLIENT_SECRET=

# --- Kitsu (Resource Owner Password) ----------------------------------------
# Kitsu has not implemented per-app registration yet; their docs publish a
# shared placeholder client_id/secret. Empty strings also work. Fill these in
# only once Kitsu rolls out real app registration.
EXPO_PUBLIC_KITSU_CLIENT_ID=
KITSU_CLIENT_SECRET=
